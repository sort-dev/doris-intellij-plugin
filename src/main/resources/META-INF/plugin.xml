<idea-plugin>
    <id>dev.sort.doris-intellij-plugin</id>
    <name>SQL Dialect for Apache Doris</name>
    <vendor url="https://sort.dev" email="jayson@sort.dev">Sortdev SRL</vendor>

    <description><![CDATA[
        <p>Apache Doris SQL dialect and data-source support for DataGrip and IntelliJ IDEA Ultimate.</p>

        <ul>
            <li>Dedicated <b>DorisSQL dialect</b> with correct statement and run-block boundaries for
                Doris syntax the generic MySQL dialect mis-parses: <code>INSERT OVERWRITE</code>,
                <code>SELECT * EXCEPT(...)</code>, <code>QUALIFY</code>, <code>CREATE JOB</code>,
                materialized views, <code>DISTRIBUTED BY</code> / <code>PROPERTIES</code> DDL,
                <code>REFRESH</code>, <code>WARM UP</code>, and more</li>
            <li>Window functions, CTEs, Doris cast targets (<code>STRING</code>, <code>LARGEINT</code>,
                <code>ARRAY&lt;...&gt;</code>, <code>MAP&lt;...&gt;</code>), <code>TRY_CAST</code>,
                and map access (<code>col['key']</code>) parse with full structure and completion</li>
            <li>Completion for 825 Doris built-in functions and Doris data types
                (<code>VARIANT</code>, <code>BITMAP</code>, <code>HLL</code>, <code>AGG_STATE</code>, ...)</li>
            <li>Doris-accurate syntax validation via an embedded build of the Doris SQL parser</li>
            <li>Ready-to-use <b>Apache Doris</b> data-source template: MySQL Connector/J download,
                default port 9030, connection validation, SHOW CREATE definitions</li>
        </ul>

        <p><i>This is an independent, community plugin developed by Sortdev SRL. It is not affiliated
        with, endorsed by, or sponsored by the Apache Software Foundation. "Apache Doris", Doris, and
        the Doris logo are trademarks of the Apache Software Foundation, used here only to identify
        the database this plugin supports. For the official project see
        <a href="https://doris.apache.org/">doris.apache.org</a>.</i></p>

        <p>Source, issues and documentation:
        <a href="https://github.com/sort-dev/doris-intellij-plugin">github.com/sort-dev/doris-intellij-plugin</a></p>
    ]]></description>

    <change-notes><![CDATA[
        <b>0.2.3</b> — first public release.
        <ul>
            <li>DorisSQL dialect on the MySQL foundation with correct statement/run-block boundaries
                for Doris-specific syntax</li>
            <li>Native parsing for window functions, IF(), CTE chains, and INSERT OVERWRITE pipelines</li>
            <li><code>SELECT * EXCEPT(...)</code>, Doris cast targets, <code>TRY_CAST</code>, and
                <code>REGEXP(...)</code> handled without breaking resolution or completion</li>
            <li>825-function completion, Doris data types, Doris-accurate error checking</li>
            <li>Apache Doris driver template with automatic MySQL Connector/J download</li>
        </ul>
    ]]></change-notes>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij">
        <database.driversConfig config="config/doris-drivers.xml"/>
        <database.configValidator implementation="dev.sort.doris.DorisConfigValidator"/>
        <sql.dialect dbms="DORIS" implementationClass="dev.sort.doris.sql.DorisSqlDialect" order="first"/>
        <lang.parserDefinition language="DorisSQL" implementationClass="dev.sort.doris.sql.DorisParserDefinition"/>
        <lang.syntaxHighlighterFactory language="DorisSQL" implementationClass="dev.sort.doris.sql.DorisSyntaxHighlighterFactory"/>
        <lang.commenter language="DorisSQL" implementationClass="dev.sort.doris.sql.DorisCommenter"/>
        <highlightErrorFilter implementation="dev.sort.doris.sql.DorisHighlightErrorFilter"/>
        <daemon.highlightInfoFilter implementation="dev.sort.doris.sql.DorisHighlightInfoFilter"/>
        <externalAnnotator language="DorisSQL" implementationClass="dev.sort.doris.sql.DorisErrorAnnotator"/>
        <!-- Re-colors DorisLexer-masked spans (CAST targets, EXCEPT lists, ...) that the SQL
             highlighter would otherwise paint as comments — the highlighting lexer IS the parser
             lexer on this platform. TextAttributes only; no PSI or parser impact. -->
        <annotator language="DorisSQL" implementationClass="dev.sort.doris.sql.DorisMaskedSpanRecolorAnnotator"/>
        <completion.contributor language="DorisSQL" implementationClass="dev.sort.doris.sql.DorisCompletionContributor"/>
        <!-- Answers "do not skip autopopup" inside a registered TVF call's quoted property args,
             pre-empting the platform's SkipAutopopupInStrings (order="last", language="any"). -->
        <completion.confidence language="DorisSQL" order="first"
                               implementationClass="dev.sort.doris.sql.DorisTvfAutoPopupConfidence"/>

        <!-- Clean Doris cancel, connect-time half (gated by the `doris.cancel.experimental`
             system property, default ON; see dev.sort.doris.cancel.DorisCancel). Guarded to
             dbms=DORIS inside interceptConnection — non-Doris data sources are never touched
             (the interceptor stays inactive, handleConnected is not called). On each Doris
             connection: mints a per-connection trace id, binds it via SET session_context,
             mirrors it into the driver statement comment via setClientInfo("DorisTraceId"). -->
        <database.connectionInterceptor implementation="dev.sort.doris.cancel.DorisTraceIdConnectionInterceptor"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij.database">
        <dbms id="DORIS" instance="dev.sort.doris.DorisDbms.DORIS"/>
        <modelFacade dbms="DORIS" implementationClass="dev.sort.doris.DorisModelFacade"/>
        <definitionProvider dbms="DORIS" implementationClass="dev.sort.doris.DorisDefinitionProvider"/>
        <extensionFallback dbms="DORIS" fallbackDbms="MYSQL"/>
        <!-- Type system: exact MySQL delegation (what the extensionFallback above used to select)
             plus static output schemas for Doris table-valued functions in FROM
             (tasks/catalogs/...; see DorisTypeSystem/DorisTableFunctions). Always on. -->
        <typeSystem dbms="DORIS" implementationClass="dev.sort.doris.sql.DorisTypeSystem"/>
        <errorHandler dbms="DORIS" implementationClass="com.intellij.database.dialects.generic.GenericDatabaseErrorHandler"/>

        <!-- Experimental multi-catalog model (Gate 1 / Milestone 1, gated by the
             `doris.catalogs.experimental` system property; see dev.sort.doris.DorisCatalogs).
             All five registrations are DUAL-MODE: with the flag OFF each delegates to the exact
             MySQL implementation the `extensionFallback DORIS -> MYSQL` above would have selected,
             so flag-off behaviour is byte-for-byte unchanged. With the flag ON they switch to the
             SQL Server (Ms*) multi-database model that exposes the catalog level. -->
        <introspector dbms="DORIS" implementationClass="dev.sort.doris.catalog.DorisIntrospector$DorisIntrospectorFactory"/>
        <sqlObjectBuilder dbms="DORIS" implementationClass="dev.sort.doris.catalog.DorisObjectBuilder"/>
        <scriptGenerator dbms="DORIS" implementationClass="dev.sort.doris.catalog.DorisScriptGenerator"/>
        <hookUpHelper dbms="DORIS" implementationClass="dev.sort.doris.catalog.DorisHookUpHelper"/>
        <predicatesHelper dbms="DORIS" implementationClass="dev.sort.doris.catalog.DorisPredicatesHelper"/>
        <!-- M4: dbms-keyed database dialect. Dual-mode like the rest: flag-off it replicates the
             fallback MysqlDialect exactly (MysqlBaseDialect subclass, same getDbms/getDisplayName);
             flag-on it fixes the console namespace switcher: per-part-quoted USE `catalog`.`db`
             composition (BUG A) and the two-level catalog->database stepped popup (BUG B). -->
        <dialect dbms="DORIS" implementationClass="dev.sort.doris.catalog.DorisDatabaseDialect"/>
    </extensions>

    <!-- M9: persisted-model shape migration across the catalogs flag (RESEARCH-model-migration.md
         §5(b)). started(Project) fires SYNCHRONOUSLY before the platform reads any model file;
         mismatched-shape Doris model files are deleted for a silent empty-tree rebuild. This is
         the one deliberate always-on catalog-side behavior: it must clear catalogs-shaped files
         when the flag is OFF too (otherwise the flat loader hits them and logs
         "family not in parent" errors / drops nodes). -->
    <applicationListeners>
        <listener class="dev.sort.doris.catalog.DorisModelMigrationListener"
                  topic="com.intellij.database.dataSource.DataSourceModelStorage$Listener"/>
    </applicationListeners>

    <!-- Clean Doris cancel, cancel-time half: replaces the stock stop-button action
         (database-plugin.xml registers Console.Jdbc.Cancel; there is no dialect-level cancel
         seam — the JDBC chain ends in the MySQL driver's broken second-connection
         KILL QUERY <conn-id>, see RESEARCH-query-cancel.md). The replacement subclasses the
         stock action and delegates to it verbatim for non-Doris sessions and when
         -Ddoris.cancel.experimental=false; for Doris sessions the stock (client-side) cancel
         still runs first and a server-side KILL QUERY "<trace-id>" follows on a pooled thread.
         Text/description/icon replicate the stock registration (the platform reads them from
         the declaring plugin, i.e. us, after the override). -->
    <actions>
        <action id="Console.Jdbc.Cancel"
                class="dev.sort.doris.cancel.DorisCancelRunningStatementsAction"
                overrides="true"
                text="Cancel Running Statements"
                description="Cancel running and queued statements"
                use-shortcut-of="Stop"
                icon="AllIcons.Actions.Suspend"/>
    </actions>
</idea-plugin>
